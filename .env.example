# Required when MEDIA_DRIVER=cloudinary; ignored otherwise.
# CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud>

DATABASE_URL=postgres://localhost:5432/scrapboard

# Album debounce window: a Telegram album arrives as N updates sharing a
# media_group_id; the webhook buffers them for this many ms before dispatch.
# Optional — defaults to 1500.
# ALBUM_DEBOUNCE_MS=1500

HOST=0.0.0.0

# Shared invite code that the Telegram bot asks for when an unknown chat
# messages it. Anyone with the code can register an account.
INVITE_CODE=changeme

# local | cloudinary. Optional — defaults to local.
# MEDIA_DRIVER=local

# ngrok auth token — required in development. The dev server starts an ngrok
# tunnel automatically and uses its URL for the Telegram webhook. Get one
# from https://dashboard.ngrok.com/. Optional in production.
# NGROK_AUTHTOKEN=

NODE_ENV=development

PORT=3000

# Public base URL — used for the Telegram webhook URL in production. In
# development this is overridden by the ngrok tunnel URL. Optional —
# defaults to http://localhost:3000.
# PUBLIC_BASE_URL=http://localhost:3000

# Reminder cron — interpreted in the server's local timezone. Set to "off"
# to disable. Optional — defaults to "0 9 * * *".
# REMINDER_CRON=0 9 * * *

# Days a person must go untouched (contacted or reminded) before they're
# eligible for the next reminder. Optional — defaults to 14.
# REMINDER_COOLDOWN_DAYS=14

# 32+ char random string that signs session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

STORAGE_ROOT=./storage

# Telegram bot token from @BotFather. Optional if you don't want the bot.
# TELEGRAM_BOT_TOKEN=

# Random string passed to setWebhook; verified on every incoming update.
# Optional but strongly recommended when TELEGRAM_BOT_TOKEN is set.
# TELEGRAM_WEBHOOK_SECRET=
