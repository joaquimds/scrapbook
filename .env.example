# Runtime
NODE_ENV=development

# HTTP server
HOST=0.0.0.0
PORT=3000

AUTH_PASSWORD=keyboardcat

# Persistence
DATABASE_URL=postgres://localhost:5432/scrapbook
STORAGE_ROOT=./storage

# Telegram bot
# Token from @BotFather. Webhook secret is any random string you choose and
# pass to setWebhook; the server checks it on every incoming update. Allowed
# chat id locks the bot to a single chat — get it by messaging the bot then
# hitting https://api.telegram.org/bot<token>/getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=

# ngrok — required in development. Get one from https://dashboard.ngrok.com/.
# In dev the server starts an ngrok tunnel automatically and uses that URL
# for webhook signature verification; the URL is printed at startup.
NGROK_AUTHTOKEN=

# Public base URL — used for webhook signature verification in production.
# In development this is overridden by the ngrok tunnel URL.
PUBLIC_BASE_URL=http://localhost:3000

# Reminders (Phase 4). Set REMINDER_CRON="off" to disable. Cron is interpreted
# in the server process's local timezone. Cooldown excludes anyone touched
# (contacted or reminded) within the last N days from the selection pool.
REMINDER_CRON=0 9 * * *
REMINDER_COOLDOWN_DAYS=14
